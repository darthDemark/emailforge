# EmailForge environment variables
# Configure at least one AI provider. The platform selects providers
# in order of preference and gracefully degrades to the deterministic
# rule engine when no AI keys are present.

# AI provider selection: openai | anthropic | gemini | auto
AI_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Anthropic (model IDs must be current — older 3.5 aliases are retired)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: route Vision/Convert image analysis to a different model
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Supabase (optional - used for persistence + storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=emailforge
